# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://vault:vault_secret@localhost:5432/vault_documents
DATABASE_URL_SYNC=postgresql+psycopg2://vault:vault_secret@localhost:5432/vault_documents

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# AI API Key (only Anthropic needed — embeddings run locally)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model Configuration
CLAUDE_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# App Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Logging
LOG_LEVEL=INFO
